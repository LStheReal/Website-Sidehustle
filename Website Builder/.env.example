# === Website Builder Pipeline ===

# Apify — Google Maps scraping (compass/crawler-google-places)
# Get from: https://apify.com/ → Settings → Integrations → API token
APIFY_API_TOKEN=

# Google Sheets — OAuth credentials file path
# Download from: https://console.cloud.google.com/ (Desktop app type)
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# Optional: Auto-share created Google Sheets with this email
USER_EMAIL=

# Canonical leads sheet — set this once, all skills will always use it
# Create first sheet manually, then paste URL here
LEADS_SHEET_URL=

# Google Drive folder ID for customer file uploads (logo, images)
# Create a folder in Drive, copy the ID from the URL
DRIVE_UPLOAD_FOLDER_ID=

# SMTP — for sending cold emails from info@freshnew.ch
# Hostinger: smtp.hostinger.com / port 465 (SSL) or 587 (STARTTLS)
# Infomaniak: mail.infomaniak.com / port 465 or 587
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@freshnew.ch
SMTP_PASSWORD=
